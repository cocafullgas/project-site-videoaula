# URL pública do site em produção (ex: https://aula.seudominio.com.br)
# Se não preencher, o webhook tenta deduzir do header host da requisição.
SITE_URL=

# --- Upstash Redis (banco de dados gratuito, funciona em serverless) ---
# Crie uma conta grátis em https://upstash.com, crie um banco Redis
# e copie as duas variáveis abaixo (aparecem no dashboard do banco).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Hotmart ---
# Token de validação do Webhook (Hottok), copiado do painel:
# Ferramentas > Webhook (API e notificações) > sua configuração
HOTMART_HOTTOK=

# --- Configurações gerais ---
# Quantos dias o link de acesso fica válido
TOKEN_TTL_DAYS=30

# Senha para acessar o painel /admin/tokens?secret=...
ADMIN_SECRET=troque_isso_por_uma_senha_forte

# --- SMTP (opcional) ---
# Se preencher, o link de acesso é enviado por e-mail automaticamente
# quando o webhook da Hotmart aprova a compra.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
